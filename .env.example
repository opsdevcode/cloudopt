# CloudOpt environment configuration
# Copy to .env and adjust for local development.

# API
CLOUDOPT_API_HOST=0.0.0.0
CLOUDOPT_API_PORT=8000
CLOUDOPT_DEBUG=false

# Database (sync URL for Alembic; async for app)
CLOUDOPT_DATABASE_URL=postgresql+asyncpg://cloudopt:cloudopt@localhost:5432/cloudopt
CLOUDOPT_DATABASE_URL_SYNC=postgresql://cloudopt:cloudopt@localhost:5432/cloudopt

# Redis
CLOUDOPT_REDIS_URL=redis://localhost:6379/0

# AWS (optional for local dev)
# CLOUDOPT_AWS_REGION=us-east-1
# CLOUDOPT_AWS_ACCESS_KEY_ID=
# CLOUDOPT_AWS_SECRET_ACCESS_KEY=

# AI (optional for local dev)
# CLOUDOPT_OPENAI_API_KEY=
# CLOUDOPT_ANTHROPIC_API_KEY=
